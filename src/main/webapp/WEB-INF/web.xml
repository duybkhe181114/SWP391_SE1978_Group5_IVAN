<?xml version="1.0" encoding="UTF-8"?>
<web-app
        xmlns="https://jakarta.ee/xml/ns/jakartaee"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
                        https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
        version="6.0">

    <servlet>
        <servlet-name>orgDashboard</servlet-name>
        <servlet-class>Controller.OrganizationDashboardController</servlet-class>
    </servlet>

    
    <servlet>
        <servlet-name>createEvent</servlet-name>
        <servlet-class>Controller.CreateEventController</servlet-class>
    </servlet>

    
    <servlet>
        <servlet-name>manageVolunteers</servlet-name>
        <servlet-class>Controller.ManageVolunteersController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>loginAsUser</servlet-name>
        <servlet-class>Controller.LoginAsUserController</servlet-class>
    </servlet>

    <servlet>
        <servlet-name>registerController</servlet-name>
        <servlet-class>Controller.RegisterController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>adminDashboard</servlet-name>
        <servlet-class>Controller.AdminDashboard</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>manageEvents</servlet-name>
        <servlet-class>Controller.ManageEventsController</servlet-class>
    </servlet>
    
    <servlet>
        <servlet-name>adminReviewOrganizations</servlet-name>
        <servlet-class>Controller.AdminReviewOrganizationController</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>orgDashboard</servlet-name>
        <url-pattern>/organization/dashboard</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>createEvent</servlet-name>
        <url-pattern>/organization/create-event</url-pattern>
    </servlet-mapping>
    
<!--    <servlet-mapping>-->
<!--        <servlet-name>volunteerRegister</servlet-name>-->
<!--        <url-pattern>/volunteer/register</url-pattern>-->
<!--    </servlet-mapping>-->
    
    <servlet-mapping>
        <servlet-name>manageVolunteers</servlet-name>
        <url-pattern>/organization/manageVolunteers</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>loginAsUser</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>registerController</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>registerController</servlet-name>
        <url-pattern>/register/volunteer</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>registerController</servlet-name>
        <url-pattern>/register/organization</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>registerController</servlet-name>
        <url-pattern>/register/organization/resubmit</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>adminDashboard</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>manageEvents</servlet-name>
        <url-pattern>/admin/manage-events</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>adminReviewOrganizations</servlet-name>
        <url-pattern>/admin/review-organizations</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>adminReviewOrganizations</servlet-name>
        <url-pattern>/admin/manage-organizations</url-pattern>
    </servlet-mapping>

</web-app>
